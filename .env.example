# Sentinel environment variables
# Copy this file to .env and fill in your values.

# Where Sentinel stores sessions and metrics (default: ~/.sentinel)
# SENTINEL_HOME=C:/Users/you/.sentinel

# Ollama API base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (default: nomic-embed-text)
# SENTINEL_EMBEDDING_MODEL=nomic-embed-text

# Context token budget (default: 3000)
# SENTINEL_TOKEN_BUDGET=3000
